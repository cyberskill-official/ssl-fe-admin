{
    "name": "ssl-fe-admin",
    "type": "module",
    "version": "1.0.0",
    "scripts": {
        "build": "dotenvx run -- react-router build",
        "dev": "run-s ready start:dev",
        "generate": "graphql-codegen --config src/shared/graphql/graphql.config.ts",
        "inspect": "cyberskill inspect",
        "lint": "pnpm exec eslint . --no-cache",
        "lint:fix": "cyberskill lint:fix",
        "lint:inspect": "cyberskill lint:inspect",
        "ready": "cyberskill ready",
        "reset": "cyberskill reset",
        "start": "dotenvx run -- npx -y sirv-cli ./build/client --port ${VITE_PORT:-8002} --host 0.0.0.0 --single",
        "start:dev": "dotenvx run -- react-router dev",
        "test:e2e": "vitest --config src/shared/vitest/vitest.config.e2e.ts",
        "test:unit": "vitest --config src/shared/vitest/vitest.config.unit.ts"
    },
